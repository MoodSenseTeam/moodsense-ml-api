# ──────────────────────────────────────────────
# MoodSense ML API — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ------------------------------------------------
# Which GenAI backend to use: "gemini" or "openai"
LLM_PROVIDER = "gemini"

# --- Gemini Configuration ----------------------------------------
LLM_API_KEY = ""
GEMINI_MODEL = "gemini-3.5-flash"

# --- OpenAI-Compatible Configuration ----------------------------
# Required when LLM_PROVIDER = "openai"
OPENAI_API_KEY = ""
OPENAI_BASE_URL = ""         # e.g. "https://api.deepseek.com" for DeepSeek
OPENAI_MODEL = "deepseek-v4-flash"

# --- Server ------------------------------------------------------
# HOST = "0.0.0.0"
# PORT = 8000

# --- ML Model Tuning ---------------------------------------------
# SURVEY_MODEL_TYPE = "xgb"   # "xgb" or "rf"
# LATE_FUSION_WEIGHT = 0.5    # 0.0 (survey only) → 1.0 (text only)
